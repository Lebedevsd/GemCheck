{
  "manifest_version": 3,
  "name": "GemCheck – PoE Transfigured Gem Calculator",
  "description": "Transfigured gem EV for the Labyrinth Divine Font + Harvest swap EV for Catalysts, Essences, and Delirium Orbs. poe.ninja pricing.",
  "version": "1.2.0",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png"
    },
    "default_title": "GemCheck"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://poe.ninja/*/economy/*/skill-gems*",
        "https://poe.ninja/*/economy/*/currency*",
        "https://poe.ninja/*/economy/*/essences*",
        "https://poe.ninja/*/economy/*/delirium-orbs*",
        "https://poe.ninja/*/economy/*/astrolabes*",
        "https://poe.ninja/*/economy/*/forbidden-jewels*",
        "https://poe.ninja/*/economy/*/fragments*",
        "https://poe.ninja/*/economy/*/invitations*"
      ],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://poe.ninja/*/economy/*/skill-gems*",
        "https://poe.ninja/*/economy/*/currency*",
        "https://poe.ninja/*/economy/*/essences*",
        "https://poe.ninja/*/economy/*/delirium-orbs*",
        "https://poe.ninja/*/economy/*/astrolabes*",
        "https://poe.ninja/*/economy/*/forbidden-jewels*",
        "https://poe.ninja/*/economy/*/fragments*",
        "https://poe.ninja/*/economy/*/invitations*"
      ],
      "js": ["src/data.js", "src/loader.js", "src/content.js"],
      "run_at": "document_start"
    }
  ]
}
